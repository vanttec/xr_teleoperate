<?xml version="1.0" ?>
<robot name="g1_right_hand">
    <link name="right_hand_palm"/>
    <link name="right_hand_thumb_link"/>
    <link name="right_hand_index_link"/>
    <link name="right_hand_middle_link"/>
    <joint name="right_hand_thumb_joint" type="revolute">
        <parent link="right_hand_palm"/><child link="right_hand_thumb_link"/>
        <axis xyz="0 0 1"/><limit effort="100" lower="-1.57" upper="1.57" velocity="1.0"/>
    </joint>
    <joint name="right_hand_index_joint" type="revolute">
        <parent link="right_hand_palm"/><child link="right_hand_index_link"/>
        <axis xyz="0 0 1"/><limit effort="100" lower="-1.57" upper="1.57" velocity="1.0"/>
    </joint>
    <joint name="right_hand_middle_joint" type="revolute">
        <parent link="right_hand_palm"/><child link="right_hand_middle_link"/>
        <axis xyz="0 0 1"/><limit effort="100" lower="-1.57" upper="1.57" velocity="1.0"/>
    </joint>
</robot>
